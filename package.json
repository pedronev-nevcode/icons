{
  "name": "@pedronev-nevcode/icons",
  "version": "1.0.0",
  "description": "Librería de iconos de Nevcode",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "normalize": "node scripts/normalize.mjs",
    "build:components": "node scripts/build-components.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:components && tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "icons",
    "react",
    "svg",
    "nevcode"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedronev-nevcode/icons.git"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.2.6",
    "svgo": "^4.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
